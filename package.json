{
  "name": "volta-json-ptr",
  "version": "0.0.1-beta.3",
  "description": "JSON Pointer library",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "imports": {
    "#shared": "./src/shared/index.ts"
  },
  "exports": {
    ".": {
      "dev": "./src/runtime.ts",
      "default": "./dist/index.js"
    },
    "./bun": {
      "dev": "./src/plugins/bun.ts",
      "default": "./dist/bun.js"
    },
    "./esbuild": {
      "dev": "./src/plugins/esbuild.ts",
      "default": "./dist/esbuild.js"
    },
    "./farm": {
      "dev": "./src/plugins/farm.ts",
      "default": "./dist/farm.js"
    },
    "./macros": "./dist/macros.d.ts",
    "./vue-macros": "./dist/vue-macros.d.ts",
    "./rolldown": {
      "dev": "./src/plugins/rolldown.ts",
      "default": "./dist/rolldown.js"
    },
    "./rollup": {
      "dev": "./src/plugins/rollup.ts",
      "default": "./dist/rollup.js"
    },
    "./rspack": {
      "dev": "./src/plugins/rspack.ts",
      "default": "./dist/rspack.js"
    },
    "./unplugin": {
      "dev": "./src/plugins/index.ts",
      "default": "./dist/unplugin.js"
    },
    "./vite": {
      "dev": "./src/plugins/vite.ts",
      "default": "./dist/vite.js"
    },
    "./webpack": {
      "dev": "./src/plugins/webpack.ts",
      "default": "./dist/webpack.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js",
      "./bun": "./dist/bun.js",
      "./esbuild": "./dist/esbuild.js",
      "./farm": "./dist/farm.js",
      "./macros": "./dist/macros.d.ts",
      "./rolldown": "./dist/rolldown.js",
      "./rollup": "./dist/rollup.js",
      "./rspack": "./dist/rspack.js",
      "./unplugin": "./dist/unplugin.js",
      "./vite": "./dist/vite.js",
      "./webpack": "./dist/webpack.js",
      "./package.json": "./package.json"
    },
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "vp test run",
    "test:watch": "vp test --watch run",
    "test:ui": "vp test --ui",
    "typecheck": "tsc --noEmit",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "build": "vp pack",
    "release:prepare": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "release": "pnpm release:prepare && bumpp && pnpm publish",
    "benchmark": "vp pack && vp test bench"
  },
  "dependencies": {
    "oxc-parser": "^0.120.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@jsonjoy.com/json-pointer": "^18.1.0",
    "@oxc-project/types": "^0.121.0",
    "@vitest/ui": "^4.1.0",
    "bumpp": "^11.0.1",
    "magic-string": "^0.30.21",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unplugin": "^3.0.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm fmt & pnpm lint:fix",
    "pre-push": "pnpm fmt & pnpm lint:fix"
  },
  "packageManager": "pnpm@10.26.0"
}
